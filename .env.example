# Mirror — environment variables
# Copy this file to .env and fill in your values

# Gemini API key (free at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Admin token for Mirror API — any secret string
MIRROR_ADMIN_TOKEN=sk-mirror-changeme

# Backend: "local" (PostgreSQL via psycopg2) or "supabase"
MIRROR_BACKEND=local

# Local PostgreSQL connection string (used when MIRROR_BACKEND=local)
DATABASE_URL=postgresql://mirror:yourpassword@localhost:5432/mirror

# Supabase (only needed when MIRROR_BACKEND=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_key
